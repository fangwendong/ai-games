# IB Gateway paper trading defaults. TWS paper often uses 7497; IB Gateway paper often uses 4002.
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=17
IBKR_ACCOUNT=

# Safety defaults. Keep dry run enabled until paper order flow is verified.
IBKR_TRADING_MODE=paper
IBKR_DRY_RUN=true
IBKR_ALLOW_LIVE=false

# Comma-separated stock symbols routed to SMART/USD.
IBKR_SYMBOLS=SPY,QQQ

# Risk limits for the whole bot process.
MAX_NOTIONAL_PER_ORDER=1000
MAX_POSITION_NOTIONAL=5000
MAX_ORDERS_PER_DAY=10
MAX_DAILY_LOSS=250
ALLOW_MARKET_ORDERS=false

# Optional notification command. The default works inside a botmux/Lark session.
ALERT_COMMAND=botmux send --no-mention

